{
   "background": {
      "service_worker": "service.js"
   },
   "description": "__MSG_app_description__",
   "icons": {
      "128": "data/icons/128.png",
      "32": "data/icons/32.png",
      "48": "data/icons/48.png",
      "64": "data/icons/64.png"
   },
   "action": {
      "default_title": "__MSG_app_name__",
