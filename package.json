{
  "name": "klak-newtab",
  "version": "4.0.0",
  "description": "Digital Clock With Colorfull Designs and open new tab clock.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/code-hemu/klak-newtab.git"
  },
  "keywords": [],
  "bugs": {
    "url": "https://github.com/code-hemu/klak-newtab/issues"
  },
  "homepage": "https://github.com/code-hemu/klak-newtab#readme",
  "license": "GPLv3",
  "author": "Hemanta Gayen",
  "type": "module",
  "engines": {
    "node": ">=22",
    "npm": ">=11"
  },
  "scripts": {
    "build": "node --max-old-space-size=3072 tasks/cli.js build --all --release",
    "release:chrome": "node --max-old-space-size=3072 tasks/cli.js build --chrome --release",
    "release:edge": "node --max-old-space-size=3072 tasks/cli.js build --edge --release",
    "release:naver": "node --max-old-space-size=3072 tasks/cli.js build --naver --release",
    "release:firefox": "node --max-old-space-size=3072 tasks/cli.js build --firefox --release",
    "help": "node --max-old-space-size=3072 tasks/cli.js --help",
    "debug": "node --max-old-space-size=3072 tasks/cli.js build --all --debug",
    "debug:chrome": "node --max-old-space-size=3072 tasks/cli.js build --chrome --debug",
    "watch": "node --max-old-space-size=3072 tasks/cli.js build --all --debug --watch",
    "zip": "node --max-old-space-size=3072 tasks/cli.js zip",
    "chrome:watch": "node --max-old-space-size=3072 tasks/cli.js build --chrome --release --watch",
    "locales": "node --max-old-space-size=3072 tasks/translate.js"
  },
  "devDependencies": {
    "@craftamap/esbuild-plugin-html": "^0.9.0",
    "chokidar": "^5.0.0",
    "esbuild": "^0.27.3",
    "esbuild-sass-plugin": "^3.6.0",
    "globby": "^16.1.0",
    "yazl": "^3.3.1",
    "sass": "^1.97.3"
  }
}
